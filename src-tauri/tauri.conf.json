{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ghost-link",
  "version": "0.31.0",
  "identifier": "computer.ghostlink.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ghost link",
        "width": 1000,
        "height": 740,
        "minWidth": 420,
        "minHeight": 520,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; media-src 'self' blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: stun: turn: turns:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDExQ0M1M0U0RUVGQkVFQUYKUldTdjd2dnU1RlBNRWNiaDJ0Sjc4R0UraC9GUk5KRnFWaXZKckNkVDB3SUdKanh0TTBjZzhNYm4K",
      "endpoints": [
        "https://github.com/julo0211/ghost-link/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
